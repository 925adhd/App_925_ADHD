# ============================================================
# SECURITY — never commit these
# ============================================================

# All env files — no exceptions
.env
.env.*
*.local

# Private keys, certificates, credentials
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
secrets.json
credentials.json
serviceAccountKey.json

# Pre-deployment security checklist (contains security architecture details)
SECURITY.md

# ============================================================
# AUDIO FILES (too large for GitHub — host separately)
# ============================================================

public/audio/*.wav
public/audio/*.mp3

# ============================================================
# DEPENDENCIES
# ============================================================

node_modules

# ============================================================
# BUILD OUTPUT
# ============================================================

dist
dist-ssr
build

# ============================================================
# TYPESCRIPT
# ============================================================

*.tsbuildinfo

# ============================================================
# TESTING & COVERAGE
# ============================================================

coverage
.nyc_output

# ============================================================
# DEPLOYMENT & HOSTING
# ============================================================

# Vercel local config (generated by `vercel dev`, not needed in repo)
.vercel

